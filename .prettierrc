{
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "useTabs": false,
  "printWidth": 100,
  "plugins": ["prettier-plugin-astro"],
  "overrides": [
    {
      "files": "*.astro",
      "options": {
        "parser": "astro"
      }
    },
    {
      "files": ["*.mdx", "*.md"],
      "options": {
        "proseWrap": "preserve",
        "embeddedLanguageFormatting": "auto"
      }
    }
  ]
}

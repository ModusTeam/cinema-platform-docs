---
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default {...Astro.props} />

<footer
  class="mt-12 border-t border-[var(--sl-color-gray-6)] pt-8 text-sm text-zinc-500 dark:text-zinc-400"
>
  <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
    <div class="text-center md:text-left">
      © {new Date().getFullYear()} Cinema Platform Docs. Єдине джерело істини.
    </div>

    <div class="flex items-center gap-6 font-semibold">
      <a
        href="https://github.com/stkossman/cinema-platform-front"
        target="_blank"
        class="transition-colors duration-200 hover:text-[var(--sl-color-accent)]"
      >
        Frontend
      </a>
      <a
        href="https://github.com/stkossman/cinema-platform-back"
        target="_blank"
        class="transition-colors duration-200 hover:text-[var(--sl-color-accent)]"
      >
        Backend
      </a>
      <a
        href="https://modusteam.github.io/"
        target="_blank"
        class="transition-colors duration-200 hover:text-[var(--sl-color-accent)]"
      >
        ModusTeam
      </a>
    </div>
  </div>
</footer>

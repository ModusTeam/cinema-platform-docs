<custom-theme-toggle class="flex items-center">
  <label
    class="relative inline-flex cursor-pointer items-center"
    title="Toggle Theme"
  >
    <input type="checkbox" class="peer sr-only" id="theme-toggle-checkbox" />

    <div
      class="peer h-7 w-14 rounded-full border border-zinc-300 bg-zinc-200 shadow-sm transition-colors duration-300 after:absolute after:top-[3px] after:left-[3px] after:h-[20px] after:w-[20px] after:rounded-full after:border after:border-zinc-200 after:bg-white after:transition-all after:duration-300 after:content-[''] peer-checked:after:translate-x-7 dark:border-[var(--sl-color-gray-6)] dark:bg-[var(--sl-color-gray-5)] dark:after:border-transparent dark:after:bg-[var(--sl-color-accent-low)]"
    >
    </div>

    <svg
      class="pointer-events-none absolute left-[7px] h-3.5 w-3.5 scale-100 text-zinc-500 opacity-100 transition-all duration-300 dark:scale-50 dark:opacity-0"
      fill="currentColor"
      viewBox="0 0 20 20"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"
        fill-rule="evenodd"
        clip-rule="evenodd"></path>
    </svg>

    <svg
      class="pointer-events-none absolute right-[7px] h-3.5 w-3.5 scale-50 text-[var(--color-primary)] opacity-0 transition-all duration-300 dark:scale-100 dark:opacity-100"
      fill="currentColor"
      viewBox="0 0 20 20"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
      ></path>
    </svg>
  </label>
</custom-theme-toggle>

<script>
  class CustomThemeToggle extends HTMLElement {
    constructor() {
      super();
      const checkbox = this.querySelector('input');
      if (!checkbox) return;

      const currentTheme = document.documentElement.dataset.theme;
      checkbox.checked = currentTheme === 'dark';

      checkbox.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        const theme = target.checked ? 'dark' : 'light';

        document.documentElement.dataset.theme = theme;

        if (typeof localStorage !== 'undefined') {
          localStorage.setItem('starlight-theme', theme);
        }
      });

      window.addEventListener('storage', (e) => {
        if (e.key === 'starlight-theme') {
          checkbox.checked = e.newValue === 'dark';
        }
      });
    }
  }

  customElements.define('custom-theme-toggle', CustomThemeToggle);
</script>
